# ═══════════════════════════════════════════════════════════════════
# SpartinaTech Auto Image Generation - Environment Variables
# ═══════════════════════════════════════════════════════════════════

# ─── OpenAI API ───
# Get your API key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# Image generation model: gpt-image-1 (best quality, ~$0.04-0.19/img)
# Alternatives: dall-e-2 (~$0.016/img, cheapest), dall-e-3 (~$0.04-0.12/img)
OPENAI_IMAGE_MODEL=gpt-image-1

# Number of images to generate per batch (default: 30)
IMAGE_COUNT=30

# Image size: 1024x1024, 1024x1536 (portrait), 1536x1024 (landscape)
OPENAI_IMAGE_SIZE=1024x1024

# ─── Feishu / Lark Delivery ───
# Mode A: Custom Bot Webhook (simplest, send card messages with download links)
# Create at: Feishu Group → Settings → Group Bot → Add → Custom Bot
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx

# Mode B: App API (upload ZIP files directly to Feishu)
# Get credentials at: https://open.feishu.cn/app
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Target group chat ID (米草科技有限公司群)
FEISHU_CHAT_ID=oc_a416c665d186a8d388f96327047700f9

# ─── Website / Deployment ───
SITE_URL=https://spartina.tech

# API route auth token (for the /api/auto-images endpoint)
AUTOMATIC_IMAGES_TOKEN=your-secret-token-here

# ─── GitHub Actions (set as repository secrets) ───
# In GitHub repo: Settings → Secrets and variables → Actions
# Add the following secrets:
#   OPENAI_API_KEY
#   FEISHU_WEBHOOK_URL
#   FEISHU_APP_ID (optional)
#   FEISHU_APP_SECRET (optional)
#   FEISHU_CHAT_ID
