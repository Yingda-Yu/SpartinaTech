{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "framework": "next",
  "functions": {
    "api/*.ts": {
      "runtime": "@vercel/node@3.2.12",
      "memory": 128
    }
  },
  "installCommand": "npm install",
  "outputDirectory": ".vercel/output",
  "regions": ["hkg1"]
}
